# QAlytics Environment Variables
# Copy this file to .env and fill in values

# JWT secret - CHANGE THIS in production
SECRET_KEY=qalytics-super-secret-dev-key-change-me-in-prod

# SQLAlchemy database URL
DATABASE_URL=sqlite:///./backend/qalytics.db

# Default test environment
QA_ENV=staging

# CORS origins allowed to call the API
CORS_ALLOWED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000,http://127.0.0.1:8000,http://localhost:8000

# Bootstrap admin user created on startup when enabled
BOOTSTRAP_ADMIN_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=change-this-password
BOOTSTRAP_ADMIN_EMAIL=admin@qalytics.dev
BOOTSTRAP_ADMIN_ROLE=admin

# Allure CLI path (if not on system PATH)
# ALLURE_BIN=/usr/local/bin/allure
